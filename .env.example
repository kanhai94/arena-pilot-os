NODE_ENV=development
PORT=4000
MONGO_URI=mongodb://mongodb:27017/sports_academy
REDIS_URL=redis://redis:6379
LOG_LEVEL=info
LOG_DIR=logs
CORS_ORIGIN=http://localhost:3000
REQUEST_BODY_LIMIT=1mb
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
RATE_LIMIT_AUTH_MAX=40
JWT_ACCESS_SECRET=replace-with-minimum-32-characters-access-secret
JWT_REFRESH_SECRET=replace-with-minimum-32-characters-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api/v1
