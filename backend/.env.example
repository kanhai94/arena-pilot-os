NODE_ENV=development
PORT=4000
MONGO_URI=mongodb://localhost:27017/sports_academy
REDIS_URL=redis://localhost:6379
LOG_LEVEL=info
LOG_DIR=logs
CORS_ORIGIN=http://localhost:3000
REQUEST_BODY_LIMIT=1mb
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
RATE_LIMIT_AUTH_MAX=40
JWT_ACCESS_SECRET=replace-with-minimum-32-characters-access-secret
JWT_REFRESH_SECRET=replace-with-minimum-32-characters-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=5
EMAIL_USER=your-gmail@example.com
EMAIL_PASS=your-app-password
EMAIL_FROM=your-gmail@example.com
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_FROM_NAME=ArenaPilot OS
BREVO_API_KEY=your-brevo-api-key
BREVO_API_URL=https://api.brevo.com/v3/smtp/email
OTP_SUBJECT_SIGNUP=Verify your Sports Academy account
OTP_SUBJECT_FORGOT=Reset your Sports Academy account password
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx
SUPER_ADMIN_NAME=Super Admin
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=replace-with-secure-password
ACADEMY_CODE_PREFIX=kan
ACADEMY_CODE_PAD=2
